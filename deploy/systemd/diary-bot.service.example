[Unit]
Description=Telegram Diary Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/diary-bot
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/diary-bot/.venv/bin/python /opt/diary-bot/bot.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
