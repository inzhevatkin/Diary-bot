TELEGRAM_BOT_TOKEN=123456:replace_with_token_from_botfather

# Optional, but recommended after you run /start once.
# Without this, the bot accepts messages from any chat that knows its username.
ALLOWED_CHAT_IDS=

# Local time for daily wellbeing questions.
TIMEZONE=Asia/Novosibirsk
QUESTIONS_TIME=20:00

# Optional. Used for voice transcription, photo description and text summaries.
OPENAI_API_KEY=

# Optional. Used for text summaries.
GIGACHAT_API_KEY=
GIGACHAT_VERIFY_SSL_CERTS=true
